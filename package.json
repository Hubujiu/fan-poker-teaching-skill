{
  "name": "@hubujiu/fan-poker-deck",
  "version": "2.0.0",
  "description": "Dependency-free Web Component for fan-shaped decks of isolated, fully custom scrollable card worlds.",
  "type": "module",
  "main": "./dist/fan-poker.js",
  "module": "./dist/fan-poker.js",
  "browser": "./dist/fan-poker.js",
  "types": "./types/fan-poker.d.ts",
  "customElements": "./custom-elements.json",
  "exports": {
    ".": {
      "types": "./types/fan-poker.d.ts",
      "import": "./dist/fan-poker.js",
      "default": "./dist/fan-poker.js"
    },
    "./custom-elements.json": "./custom-elements.json",
    "./package.json": "./package.json"
  },
  "unpkg": "./dist/fan-poker.js",
  "jsdelivr": "./dist/fan-poker.js",
  "files": [
    "dist",
    "types",
    "src",
    "docs",
    "custom-elements.json",
    "README.md",
    "README_EN.md",
    "LICENSE"
  ],
  "sideEffects": [
    "./dist/fan-poker.js",
    "./src/fan-poker.js"
  ],
  "scripts": {
    "build": "node scripts/build.mjs",
    "test": "npm run build && npm run test:static && npm run test:node && npm run test:size",
    "test:static": "node scripts/validate.mjs",
    "test:node": "node scripts/node-smoke.mjs",
    "test:size": "node scripts/size-check.mjs",
    "test:browser": "bash scripts/browser-smoke.sh",
    "prepublishOnly": "npm test"
  },
  "keywords": [
    "web-component",
    "custom-elements",
    "agent-skill",
    "interactive-tutorial",
    "education",
    "html",
    "custom-card",
    "scroll-container",
    "poker-cards",
    "shadow-dom",
    "ssr-safe"
  ],
  "homepage": "https://hubujiu.github.io/fan-poker-teaching-skill/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Hubujiu/fan-poker-teaching-skill.git"
  },
  "bugs": {
    "url": "https://github.com/Hubujiu/fan-poker-teaching-skill/issues"
  },
  "author": "Hubujiu",
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "engines": {
    "node": ">=18"
  }
}
